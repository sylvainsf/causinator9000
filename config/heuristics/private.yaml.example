# RCIE Private Heuristic Overrides — Example
#
# This file demonstrates "lean patching".  Only the fields you include
# are overridden; everything else is inherited from earlier layers.
#
# To activate, rename this file to private.yaml and uncomment the
# corresponding line in heuristics.manifest.yaml.

# ── Override a single CPT weight ──────────────────────────────────────
# Increase the Container / ImageUpdate → CrashLoopBackOff signal weight
# from the public default of 0.75 to 0.85.  All other Container CPTs
# remain unchanged.

- class: Container
  cpts:
    - mutation: ImageUpdate
      signal: CrashLoopBackOff
      table:
        - [0.85, 0.03]
        - [0.15, 0.97]

# ── Override default_prior only ───────────────────────────────────────
# Lower the background failure rate for RedisCache without touching
# any CPT entries.

- class: RedisCache
  default_prior:
    P_failure: 0.001

# ── Add a brand-new class ────────────────────────────────────────────
# Introduce CPTs for an internal service not in the public registry.

- class: InternalGrpcProxy
  default_prior:
    P_failure: 0.004
  cpts:
    - mutation: ConfigReload
      signal: error_rate
      table:
        - [0.70, 0.05]
        - [0.30, 0.95]
