# Causinator 9000 — Environment Configuration
#
# Copy this file to .env and fill in your values.
# .env is gitignored — your secrets stay local.
#
# The Makefile and source scripts read these automatically.

# ── Engine ───────────────────────────────────────────────────────────────
C9K_ENGINE_URL=http://localhost:8080
C9K_ENGINE_PORT=8080

# ── Azure ────────────────────────────────────────────────────────────────
# Subscription ID (auto-detected from `az account show` if not set)
# AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# Comma-separated list of additional subscriptions to query
# AZURE_EXTRA_SUBSCRIPTIONS=

# ── GitHub ───────────────────────────────────────────────────────────────
# Repositories to monitor (comma-separated owner/name)
GH_REPOS=project-radius/radius

# How far back to look for workflow runs (hours)
GH_HOURS=48

# Webhook secret for real-time receiver (optional)
# GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# Webhook receiver port
GH_WEBHOOK_PORT=8090

# ── Ingestion ────────────────────────────────────────────────────────────
# Azure Resource Changes lookback (hours)
AZURE_CHANGES_HOURS=48

# Temporal window for the solver (minutes) — set on engine startup
# C9K_TEMPORAL_WINDOW=1440

# ── Heuristics ───────────────────────────────────────────────────────────
# Path to heuristics manifest (default: config/heuristics.manifest.yaml)
# C9K_HEURISTICS=config/heuristics.manifest.yaml

# ── Drasi / Kubernetes ───────────────────────────────────────────────────
# kubectl context for the K8s source (auto-detected if not set)
# DRASI_K8S_CONTEXT=radlrtest00-aks

# AKS ARM resource ID for cross-linking K8s pods to ARG topology
# DRASI_AKS_RESOURCE_ID=/subscriptions/.../providers/Microsoft.ContainerService/managedClusters/...

# Namespaces to monitor (comma-separated, default: all)
# K8S_NAMESPACES=radius-system,dapr-system,default

# ── Event Grid (future) ─────────────────────────────────────────────────
# Event Grid webhook receiver port
# EVENTGRID_WEBHOOK_PORT=8091

# ── Entra (future) ──────────────────────────────────────────────────────
# Log Analytics workspace ID for Entra audit logs
# ENTRA_WORKSPACE_ID=
